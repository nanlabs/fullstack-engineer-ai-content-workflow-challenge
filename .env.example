# Database
DATABASE_URL=postgresql://acme:acme_pass@localhost:5432/acme_content

# JWT Authentication
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRATION=24h

# LLM Provider (gpt-5.4-mini | gpt-5.4 | claude-sonnet-4.6 | claude-haiku-4.5 | gemini-2.5-flash-lite | gemini-flash-2.5)
DEFAULT_LLM_PROVIDER=gpt-5.4-mini

# API Keys - set at least the key for your DEFAULT_LLM_PROVIDER
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
